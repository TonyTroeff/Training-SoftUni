              "schema": "{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\",\n  \"title\": \"Event\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"name\": {\n      \"type\": \"string\",\n      \"description\": \"Name of the event\"\n    },\n    \"type\": {\n      \"type\": \"string\",\n      \"enum\": [\"Lecture\", \"Workshop\", \"Other\"],\n      \"description\": \"Type of the event\"\n    },\n    \"date\": {\n      \"type\": \"string\",\n      \"format\": \"date\",\n      \"description\": \"Date of the event in YYYY-MM-DD format\"\n    },\n    \"realtime\": {\n      \"type\": \"boolean\",\n      \"description\": \"Whether the event is in real-time\"\n    }\n  },\n  \"required\": [\"name\", \"type\", \"date\", \"realtime\"],\n  \"additionalProperties\": false\n}",
