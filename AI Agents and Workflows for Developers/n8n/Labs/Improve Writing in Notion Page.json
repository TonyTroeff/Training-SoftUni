      "position": [
        -256,
        -16
      ],
      "id": "f4744d26-53c7-40d5-9883-e01dab9ac2ad",
      "name": "Split Out"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Add a new field called 'myNewField' to the JSON of the item\nconst enhancedContent = $input.item.json.output[0].content[0].text.split('\\n').filter(x => x != '');\n\nconst originalContentBlocks = $('Aggregate Content Blocks').first().json.contentBlocks;\nif (enhancedContent.length != originalContentBlocks.length) throw new Error(\"Content block arrays have different length.\");\n\nreturn {\n    data: enhancedContent.map((x, idx) => ({ ...originalContentBlocks[idx], content: x }))\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -480,
        -16
      ],
      "id": "d031d25e-e5ae-4fde-8a68-47b6f47d4d02",
      "name": "Extract Enhanced Content Blocks"
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "nvidia/nemotron-3-nano-4b",
          "mode": "list",
          "cachedResultName": "NVIDIA/NEMOTRON-3-NANO-4B"
        },
        "responses": {
          "values": [
            {
              "role": "system",
              "content": "You are a professional writing editor. Your task is to improve the clarity, grammar, flow, and style of the given text blocks.\n\nINPUT FORMAT:\n- You will receive multiple text blocks formatted as: [<type>] <text>\n\nINSTRUCTIONS:\n- Improve each block independently.\n- Preserve the original meaning, intent, and factual content.\n- Maintain the original tone and style (e.g., formal remains formal, casual remains casual).\n- Correct grammar, punctuation, clarity, and sentence flow.\n- Make wording more natural and concise where appropriate.\n\nOUTPUT RULES:\n- Output ONLY the improved text.\n- Return each improved block on a separate line.\n- Do NOT add, remove, merge, split, or reorder blocks.\n- Do NOT include commentary, explanations, labels, or formatting notes.\n- Do NOT modify the content of headings - use them only as a reference.\n- Do NOT repeat the [<type>] tags.\n- Do NOT skip any blocks.\n- Every non-heading text block must end with a period."
            },
            {
              "content": "={{ $json.contentBlocks.map((x, idx) => `[${x.type}] ${x.content}`).join('\\n') }}"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
